programa {
  funcao inicio() {
    inteiro contador , numero , maior
    contador < 1
    enquanto (contador <=5){
      escreva("digite o seu numero ")
      leia(numero )

      }se (contador = 1){
        maior < numero
        senao
        se (numero > maior){
          maior < numero
        }contador < contador +1

      }escreva("maior numero " , maior)

    }

  }
}

programa {
  funcao inicio() {
    inteiro contador
    real soma , media , nota
    contador< 0
    soma < 1
    enquanto(contador <=4){
     escreva ("digite a sua nota ")
     leia(nota)
     soma < soma + nota
     contador < contador +1

    }media < soma  / 4
    escreva("media final " , media)
  }
}
